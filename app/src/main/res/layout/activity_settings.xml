<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:animateLayoutChanges="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textColor="@color/primary_light_blue"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Minecraft 版本文件夹名"
            android:textColorHint="#AAFFFFFF"
            app:hintTextColor="@color/primary_light_blue"
            app:boxStrokeColor="@color/primary_light_blue"
            app:boxBackgroundColor="#2A2A2A">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etVersionName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1.21.1-NeoForge"
                android:textColor="@android:color/white"
                android:singleLine="true"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="下载线程数 (20-128)"
            android:textColorHint="#AAFFFFFF"
            app:hintTextColor="@color/primary_light_blue"
            app:boxStrokeColor="@color/primary_light_blue"
            app:boxBackgroundColor="#2A2A2A">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etThreadCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="20"
                android:textColor="@android:color/white"
                android:inputType="number"
                android:singleLine="true"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Ping(Server) 区域 -->
        <Button
            android:id="@+id/btnPingServer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ping (Server)"
            android:textColor="@android:color/black"
            android:backgroundTint="@color/primary_light_blue"
            android:layout_marginTop="24dp"
            android:textSize="16sp"/>
        <TextView
            android:id="@+id/tvPingServerResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/primary_light_blue"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="#1E1E1E"
            android:padding="8dp"
            android:visibility="gone"/>

        <!-- Ping(WiFi) 区域 -->
        <Button
            android:id="@+id/btnPingWifi"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ping (WiFi)"
            android:textColor="@android:color/black"
            android:backgroundTint="@color/primary_light_blue"
            android:layout_marginTop="16dp"
            android:textSize="16sp"/>
        <TextView
            android:id="@+id/tvPingWifiResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/primary_light_blue"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="#1E1E1E"
            android:padding="8dp"
            android:visibility="gone"/>

        <!-- 扩展模式开关 -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swExtensionMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="扩展模式"
            android:textColor="@android:color/white"
            android:layout_marginTop="24dp"
            android:checked="false"/>

        <Button
            android:id="@+id/btnExportLog"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="导出日志"
            android:textColor="@android:color/black"
            android:backgroundTint="@color/primary_light_blue"
            android:layout_marginTop="24dp"
            android:textSize="16sp"/>
    </LinearLayout>
</ScrollView>
