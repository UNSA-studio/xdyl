<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="设置"
        android:textColor="@color/primary_light_blue"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Minecraft 版本文件夹名"
        android:textColorHint="#AAFFFFFF"
        app:hintTextColor="@color/primary_light_blue"
        app:boxStrokeColor="@color/primary_light_blue"
        app:boxBackgroundColor="#2A2A2A">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etVersionName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1.21.1-NeoForge"
            android:textColor="@android:color/white"
            android:singleLine="true"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="下载线程数 (20-128)"
        android:textColorHint="#AAFFFFFF"
        app:hintTextColor="@color/primary_light_blue"
        app:boxStrokeColor="@color/primary_light_blue"
        app:boxBackgroundColor="#2A2A2A">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etThreadCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="20"
            android:textColor="@android:color/white"
            android:inputType="number"
            android:singleLine="true"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnExportLog"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="导出日志"
        android:textColor="@android:color/black"
        android:backgroundTint="@color/primary_light_blue"
        android:layout_marginTop="32dp"
        android:textSize="16sp"/>

    <Button
        android:id="@+id/btnGreenScreen"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="千万别点!"
        android:textColor="#FFFF0000"
        android:backgroundTint="#FF333333"
        android:layout_marginTop="16dp"
        android:textSize="16sp"
        android:textStyle="bold"/>
</LinearLayout>
