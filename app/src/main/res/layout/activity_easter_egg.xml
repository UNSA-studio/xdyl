<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:animateLayoutChanges="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="扩展页面"
                android:textColor="@color/primary_light_blue"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="线程数上限 (128-1024)"
                android:textColorHint="#AAFFFFFF"
                app:hintTextColor="@color/primary_light_blue"
                app:boxStrokeColor="@color/primary_light_blue"
                app:boxBackgroundColor="#2A2A2A">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etThreadLimit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="256"
                    android:textColor="@android:color/white"
                    android:inputType="number"
                    android:singleLine="true"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swNeoforgeCheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开启 NeoForge 版本检查"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:checked="false"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swCleanOrphanFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="更新后自动清理多余文件"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:checked="true"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swLocalCsv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="使用本地 CSV 文件"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:checked="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickCsv"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="选择 CSV 文件"
                android:textColor="@android:color/black"
                app:backgroundTint="@color/primary_light_blue"
                android:layout_marginTop="12dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownloadUrl"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="自定义下载地址"
                android:textColor="@android:color/black"
                app:backgroundTint="@color/primary_light_blue"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAchievements"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="成就"
                android:textColor="@android:color/black"
                app:backgroundTint="@color/primary_light_blue"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
