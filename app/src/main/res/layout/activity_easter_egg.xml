<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:animateLayoutChanges="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="扩展页面"
                android:textColor="@color/primary_light_blue"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swUnlockThread"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="解锁线程数上限至 1024"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:checked="false"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swNeoforgeCheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开启 NeoForge 版本检查"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:checked="true"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swCleanOrphanFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="更新后自动清理多余文件"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:checked="true"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swLocalCsv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="使用本地 CSV 文件"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:checked="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickCsv"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="选择 CSV 文件"
                android:textColor="@android:color/black"
                app:backgroundTint="@color/primary_light_blue"
                android:layout_marginTop="12dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWhitelist"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="模组白名单"
                android:textColor="@android:color/black"
                app:backgroundTint="@color/primary_light_blue"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="重置登记状态"
                android:textColor="@android:color/black"
                app:backgroundTint="@color/primary_light_blue"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
